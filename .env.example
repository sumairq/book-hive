# MongoDB
MONGODB_URI=mongodb://localhost:27017/book-hive

# JWT secrets — generate with: openssl rand -base64 48
# Both must be different from each other.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string-at-least-32-bytes
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string

# Token lifetimes (any value accepted by `jose` / vercel/ms)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Public app URL (used for CORS, cookie domain decisions, and SEO metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NODE_ENV is set automatically by Next.js — do not override in .env files.
